{
  "name": "@andycoupe/orchestrator",
  "version": "0.0.1",
  "type": "module",
  "bin": {
    "orchestrator": "dist/server/cli.js"
  },
  "files": [
    "dist/",
    "prompts/",
    "templates/"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,green \"tsx watch server/index.ts | pino-pretty\" \"vite\"",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && vite build",
    "build:server": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@hono/node-server": "^1.14.1",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.75.5",
    "better-sqlite3": "^11.9.1",
    "chokidar": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "execa": "^9.5.3",
    "hono": "^4.7.10",
    "lucide-react": "^0.488.0",
    "pino": "^9.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^3.8.1",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "ulid": "^2.3.0",
    "yaml": "^2.7.1",
    "zod": "^3.24.4",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.5",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "eslint": "^9.26.0",
    "jsdom": "^26.1.0",
    "pino-pretty": "^13.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.1.5",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.3.4",
    "vitest": "^3.1.3"
  }
}
